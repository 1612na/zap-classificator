# Chave da API Anthropic para classificação LLM
# Obter em: https://console.anthropic.com
# Opcional — sem ela, conversas ambíguas ficam como 'indefinido'
ANTHROPIC_API_KEY=sk-ant-...

# URL base da Render API (sem barra no final)
# Ex: https://zap-api.onrender.com
RENDER_API_URL=https://sua-render-api.onrender.com

# Chave secreta compartilhada entre o coletor e a Render API
# Gere com: openssl rand -hex 32
RENDER_API_KEY=sua-chave-secreta-aqui

# Porta do dashboard (padrão: 3000)
PORT=3000

# Sync histórico completo na primeira conexão (padrão: false).
# Ativar APENAS para carga inicial — desligar depois para evitar risco de ban.
# Após ativar, apagar data/auth/ e reiniciar para forçar novo QR scan.
SYNC_FULL_HISTORY=false
