{
  "name": "zap-classificator",
  "version": "0.1.0",
  "description": "Sistema local de leitura, sincronização e classificação de conversas WhatsApp via Baileys",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:baileys": "tsx src/whatsapp/auth.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.18",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.41.0",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
